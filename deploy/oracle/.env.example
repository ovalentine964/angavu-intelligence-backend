# ════════════════════════════════════════════════════════════════════
# Angavu Intelligence — Environment Variables
# Copy to .env and fill in real values before deploying
# ════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────
APP_ENV=production
APP_NAME=Angavu Intelligence
DEBUG=false
ENABLE_DOCS=false
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
API_V1_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=angavu
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=biashara
DATABASE_URL=postgresql+asyncpg://angavu:CHANGE_ME_STRONG_PASSWORD@postgres:5432/biashara
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Authentication ────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_A_DIFFERENT_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Encryption ────────────────────────────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING

# ── LLM Service ──────────────────────────────────────────────────
# Local GGUF model (Qwen 2.5 7B Q4_K_M via llama.cpp)
LLM_HOST=llama-cpp
LLM_PORT=8080
LLM_MODEL_PATH=qwen2.5-7b-q4_k_m
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
LLM_TIMEOUT=60.0
LLM_FALLBACK_ENABLED=true

# ── LLM API Fallbacks (optional) ─────────────────────────────────
GROQ_API_KEY=
DEEPSEEK_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_API_KEY=

# ── llama.cpp Model ──────────────────────────────────────────────
# Download Qwen 2.5 7B Q4_K_M GGUF and place in the models volume:
#   wget https://huggingface.co/Qwen/Qwen2.5-7B-GGUF/resolve/main/qwen2.5-7b-q4_k_m.gguf
#   docker volume create angavu-intelligence_llama-models
#   docker cp qwen2.5-7b-q4_k_m.gguf angavu-llama:/models/
LLAMA_MODEL_FILE=qwen2.5-7b-q4_k_m.gguf

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Monitoring ───────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=["https://angavu.ai","https://dashboard.angavu.ai"]

# ── WhatsApp ─────────────────────────────────────────────────────
OPENWA_URL=http://localhost:3000
OPENWA_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# ── ClickHouse (optional, for analytics) ─────────────────────────
CLICKHOUSE_URL=
CLICKHOUSE_DATABASE=biashara
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=
