# =============================================================
# Angavu Intelligence — Backend Environment Variables
# =============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Secrets should be generated with: openssl rand -hex 32
# =============================================================

# === Application ===
APP_ENV=production
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=info

# === Database (PostgreSQL) ===
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://msaidizi:CHANGE_ME@postgres:5432/msaidizi
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DB_PASSWORD=CHANGE_ME

# === Connection Pooling (PgBouncer) ===
# Direct connection to pgbouncer (preferred for app connections)
PGBOUNCER_URL=postgresql://msaidizi:CHANGE_ME@pgbouncer:6432/msaidizi
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=25

# === Read Replica (optional) ===
# Uncomment when read replica is deployed.
# DATABASE_READ_URL=postgresql+asyncpg://msaidizi_readonly:CHANGE_ME@pgbouncer:6432/msaidizi_ro

# === Redis ===
# Format: redis://:PASSWORD@HOST:PORT/DB
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# === ClickHouse (Analytics) ===
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=biashara
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=CHANGE_ME

# === Security ===
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME

# JWT RSA/ML-DSA keys (PEM-encoded). Leave empty to use HS256 with JWT_SECRET_KEY.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
SECRET_KEY=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME

# === OpenWA (WhatsApp Automation) ===
# Set to true to enable WhatsApp integration via OpenWA.
# When false, backend starts without WhatsApp and all WhatsApp
# operations are silently skipped (no errors, no blocking).
ENABLE_WHATSAPP=false
OPENWA_URL=http://openwa:3000
OPENWA_WEBHOOK_SECRET=CHANGE_ME  # Only required when ENABLE_WHATSAPP=true

# === Sentry (Error Tracking — optional) ===
# SENTRY_DSN=https://xxx@sentry.io/yyy

# === Federated Learning (optional) ===
# FL_SERVER_HOST=0.0.0.0
# FL_SERVER_PORT=8080
# FL_DIFFERENTIAL_PRIVACY_EPSILON=0.1

# === Differential Privacy ===
# Epsilon: smaller = stronger privacy (0.1 = very strong for financial data)
# Override via env var to tune privacy/utility tradeoff
DIFFERENTIAL_PRIVACY_EPSILON=0.1

# === Secret Rotation ===
SECRET_ROTATION_ENABLED=true
SECRET_ROTATION_ENCRYPTION_DAYS=90
SECRET_ROTATION_JWT_DAYS=30
SECRET_ROTATION_WEBHOOK_DAYS=90
SECRET_ROTATION_API_KEY_DAYS=180
SECRET_ROTATION_GRACE_HOURS=24
SECRET_ROTATION_ENDPOINT_ENABLED=true

# === Prompt Guard ===
ANGAVU_PROMPT_GUARD_ENABLED=true
ANGAVU_PROMPT_GUARD_STRICT=false

# === Post-Quantum Cryptography ===
ANGAVU_PQC_PHASE=1
ANGAVU_PQC_HYBRID_KEX=true
ANGAVU_PQC_SIGNING=true
