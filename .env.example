# =============================================================
# Biashara Intelligence — Environment Configuration
# =============================================================
# Copy to .env and fill in your values.
# For Oracle Cloud deploy, use deploy.sh which auto-generates secrets.
#
# Profiles:
#   MICRO (E2.Micro 1GB) → SQLite, 1 worker, no Redis
#   ARM   (A1.Flex 24GB) → PostgreSQL, 4 workers, Redis
# =============================================================

# ─── Application ──────────────────────────────────────────
APP_ENV=production
APP_NAME=Biashara Intelligence
DEBUG=false
LOG_LEVEL=WARNING
API_V1_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────
# MICRO profile (SQLite — zero config):
# DATABASE_URL=sqlite+aiosqlite:///./data/biashara.db
#
# ARM profile (PostgreSQL):
DATABASE_URL=postgresql+asyncpg://biashara:CHANGEME@postgres:5432/biashara

# Connection pool — Tier 2 defaults (keep low on micro: 5/2)
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_ECHO=false

# ─── Redis (optional — empty = in-memory cache fallback) ──
# Leave empty for MICRO profile to save ~30MB RAM
# ARM/Growth profile: include password for security
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# ─── Security (auto-generated by deploy.sh) ──────────────
SECRET_KEY=CHANGE_ME_32_CHARS_MIN
JWT_SECRET_KEY=CHANGE_ME_32_CHARS_MIN
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MIN
DATA_ENCRYPTION_SALT=CHANGE_ME
OPENWA_WEBHOOK_SECRET=CHANGE_ME

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=*

# ─── ClickHouse (analytical queries, 600M+ records) ─────
# Leave empty to disable; 30-200x faster than PostgreSQL for analytics
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=biashara
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=CHANGE_ME

# ─── External APIs (optional) ─────────────────────────────
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# ─── Monitoring (optional) ────────────────────────────────
SENTRY_DSN=
