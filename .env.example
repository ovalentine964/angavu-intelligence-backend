# Msaidizi Backend Configuration
# Copy to .env and fill in real values

# Database
DATABASE_URL=postgresql://msaidizi:CHANGE_ME@localhost:5432/msaidizi

# JWT (REQUIRED - generate with: openssl rand -hex 64)
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=3600
REFRESH_TOKEN_EXPIRE_SECONDS=604800

# Encryption (REQUIRED - generate with: openssl rand -hex 32)
ENCRYPTION_KEY=CHANGE_ME_IN_PRODUCTION

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000"]

# WhatsApp/OpenWA
OPENWA_WEBHOOK_SECRET=CHANGE_ME_IN_PRODUCTION
OPENWA_API_URL=http://openwa:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
