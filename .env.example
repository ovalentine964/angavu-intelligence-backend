# Msaidizi Backend Environment Configuration

PORT=3000
NODE_ENV=development

JWT_SECRET=your-super-secret-jwt-key-change-this

OPENWA_API_URL=http://localhost:8080
OPENWA_API_KEY=your-openwa-api-key
OPENWA_SESSION_ID=msaidizi

# DATABASE_URL=postgresql://msaidizi:password@localhost:5432/msaidizi

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

REPORT_MORNING_HOUR=8
REPORT_AFTERNOON_HOUR=13
REPORT_EVENING_HOUR=18

LOG_LEVEL=debug

ENABLE_WHATSAPP=true
ENABLE_REPORTS=true
